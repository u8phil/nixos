{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["github-mcp-server", "stdio", "--read-only"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "enabled": true
    },
    "nixos": {
      "type": "local",
      "command": ["mcp-nixos"],
      "enabled": true
    }
  }
}
